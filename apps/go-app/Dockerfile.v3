# Stage 1: Build
FROM golang:1.19-alpine AS builder
WORKDIR /app

# Good practice: copy dependency metadata first for better cache reuse
COPY go.mod ./
RUN go mod download

COPY . .
RUN go mod tidy
RUN CGO_ENABLED=0 GOOS=linux go build -v -o /app/main .

# Stage 2: Production (Distroless for maximum reduction)
FROM gcr.io/distroless/static-debian11
WORKDIR /
COPY --from=builder /app/main .

EXPOSE 8080
CMD ["/main"]
