# Stage 1: Build
FROM golang:1.19-alpine AS builder
WORKDIR /app

# Good practice: Initialize and download dependencies first
COPY go.mod* go.sum* ./
RUN if [ -f go.mod ]; then go mod download; else go mod init example/hello; fi

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -v -o /app/main .

# Stage 2: Production (Distroless for maximum reduction)
FROM gcr.io/distroless/static-debian11
WORKDIR /
COPY --from=builder /app/main .

EXPOSE 8080
CMD ["/main"]
