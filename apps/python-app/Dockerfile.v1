FROM python:3.11-bookworm

WORKDIR /app

# Bad practice: Installs build-time dependencies like gcc into the final image.
RUN apt-get update && apt-get install -y build-essential

# Bad practice: Copies everything before installing dependencies.
COPY . .

RUN pip install --no-cache-dir -r requirements.txt

EXPOSE 5000
CMD ["python", "app.py"]
